# SCM-INSIGHTS Frontend
# Copy to .env and set values. Use SCM-INSIGHTS backend URL when using separate backend.

# Backend URL – use SCM backend when running backend-scm (e.g. http://localhost:5001)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001

# Optional
# NEXT_PUBLIC_VPS_BASE_URL=
# NEXT_PUBLIC_IMAGE_API_KEY=

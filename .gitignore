# ===========================================
# SCM Insights – root .gitignore
# Do not push: secrets, build artifacts, deps, IDE, OS, logs.
# backend-scm/ and SCM-INSIGHTS/ have their own .gitignore for details.
# ===========================================

# -------------------------------------------
# Environment & secrets (all subprojects)
# -------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging
**/.env
**/.env.*

# -------------------------------------------
# SSL / keys – never commit
# -------------------------------------------
*.pem
*.key
*.crt
*.cer
**/ssl/

# -------------------------------------------
# Python (backend-scm)
# -------------------------------------------
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.pyc
**/*.pyo
**/venv/
**/env/
**/.venv/
**/ENV/
**/*.egg-info/
**/dist/
**/build/
**/.eggs/
**/.tox/
**/.nox/
**/.mypy_cache/
**/.pytest_cache/
**/.coverage
**/htmlcov/
**/coverage.xml

# -------------------------------------------
# Node / Next.js (SCM-INSIGHTS)
# -------------------------------------------
**/node_modules/
**/.pnp
**/.pnp.*
**/.next/
**/out/
**/build/
**/.vercel
**/*.tsbuildinfo
**/next-env.d.ts
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# -------------------------------------------
# IDE & editors
# -------------------------------------------
**/.vscode/
**/.idea/
**/*.iml
**/*.code-workspace
**/*.swp
**/*.swo
**/*~

# -------------------------------------------
# OS
# -------------------------------------------
**/.DS_Store
**/Thumbs.db
**/Desktop.ini

# -------------------------------------------
# Logs & temporary
# -------------------------------------------
**/logs/
**/*.log
**/tmp/
**/temp/
**/*.tmp
**/*.bak
**/*.backup

# -------------------------------------------
# Database files
# -------------------------------------------
**/*.db
**/*.sqlite
**/*.sqlite3

# -------------------------------------------
# Backend static data (large; use seed scripts)
# -------------------------------------------
backend-scm/static/*.csv
backend-scm/static/*.json
!backend-scm/static/.gitkeep

# -------------------------------------------
# Misc
# -------------------------------------------
**/*.prof

.claude

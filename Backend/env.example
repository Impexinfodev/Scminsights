# ===========================================
# SCM-INSIGHTS Backend Environment
# ===========================================
# 1. Copy to .env: copy env.example .env
# 2. Fill in your values
# 3. Do not commit .env

# ===========================================
# Flask
# ===========================================
FLASK_SECRET_KEY=your-super-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_SSL_PORT=443

# ===========================================
# Database (PostgreSQL)
# ===========================================
POSTGRES_DB_HOST=localhost
POSTGRES_DB_PORT=5432
POSTGRES_DB_USER=postgres
POSTGRES_DB_PASSWORD=your_database_password
POSTGRES_DB_NAME=scm_insights

# ===========================================
# CORS (comma-separated; add http://YOUR_IP:3000 if using LAN)
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://scminsights.ai,https://www.scminsights.ai

# ===========================================
# Email / SMTP
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=True
EMAIL_FROM_NAME=SCM Insights

# ===========================================
# Razorpay (payments in INR - test and live keys from dashboard.razorpay.com)
# ===========================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Webhook secret: generate a secure random string, set the SAME value in Razorpay Dashboard → Webhooks → Secret
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Default website/platform for payments (this site). Use same key for multi-website; set per deployment.
# Example: scminsights | website-b | website-c
PAYMENT_SOURCE_WEBSITE=scminsights

# ===========================================
# URLs (links in emails use FRONTEND_URL: dev = local, production = live)
# ===========================================
# Base URL for activation & password-reset links in emails. Set to your frontend.
FRONTEND_URL=http://localhost:3000
# Fallback if FRONTEND_URL not set
DOMAIN_URL=http://localhost:3001
BACKEND_URL=http://localhost:5001

# ===========================================
# Admin (comma-separated admin emails)
# ===========================================
WHITELISTED_ADMINS=admin@example.com

# ===========================================
# SSL (production)
# ===========================================
# SSL_CERT_PATH=cert.pem
# SSL_KEY_PATH=key.pem

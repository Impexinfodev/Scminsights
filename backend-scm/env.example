# ===========================================
# SCM-INSIGHTS Backend Environment
# ===========================================
# 1. Copy to .env: copy env.example .env
# 2. Fill in your values
# 3. Do not commit .env

# ===========================================
# Flask
# ===========================================
FLASK_SECRET_KEY=your-super-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_SSL_PORT=443

# ===========================================
# Database (PostgreSQL)
# ===========================================
POSTGRES_DB_HOST=localhost
POSTGRES_DB_PORT=5432
POSTGRES_DB_USER=postgres
POSTGRES_DB_PASSWORD=your_database_password
POSTGRES_DB_NAME=scm_insights

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=http://localhost:3001,https://scminsights.ai,https://www.scminsights.ai

# ===========================================
# Email / SMTP
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=True
EMAIL_FROM_NAME=SCM Insights

# ===========================================
# URLs
# ===========================================
DOMAIN_URL=http://localhost:3001
BACKEND_URL=http://localhost:5001

# ===========================================
# Admin (comma-separated admin emails)
# ===========================================
WHITELISTED_ADMINS=admin@example.com

# ===========================================
# SSL (production)
# ===========================================
# SSL_CERT_PATH=cert.pem
# SSL_KEY_PATH=key.pem
